# === RTSP Camera Configuration ===
# Camera list (required)
# Format: name=rtsp://...;name2=rtsp://... (separated by semicolon)
# Supports raw/unquoted RTSP query strings (including & and ;) with the built-in dotenv parser,
# but quoting the full value is still recommended for readability.
# Example:
# CAMERAS=front=rtsp://user:pass@192.168.1.10:554/stream1;back=rtsp://user:pass@192.168.1.11:554/stream1
CAMERAS=

# === Recording Settings ===
# Directory to store recordings (inside container: /data/camera, bare-metal: /opt/record/camera)
RECORD_DIR=/data/camera

# Recording duration per segment in seconds (310 = 5 minutes + 10s bù trễ)
RECORD_DURATION=310

# === Rclone Cloud Sync ===
# Rclone remote name (as configured in rclone.conf)
RCLONE_REMOTE=cam

# Cloud folder path (on the remote)
RCLONE_PATH=camera

# Delete local files after successful sync (true/false)
DELETE_AFTER_SYNC=true

# Max disk usage percentage before forced cleanup (0 to disable)
DISK_USAGE_THRESHOLD=80

# === System ===
# Timezone (used for directory naming and cron scheduling)
TZ=Asia/Ho_Chi_Minh
